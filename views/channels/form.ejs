<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NovaStream Admin - <%= channel && channel._id ? 'Edit' : 'New' %> Channel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/sidebar') %>

  <main class="main">
    <div class="page-header">
      <div>
        <h2><%= channel && channel._id ? 'Edit' : 'New' %> Channel</h2>
        <p><%= channel && channel._id ? 'Update channel details' : 'Add a new live channel' %></p>
      </div>
      <a href="/admin/channels" class="btn btn-secondary">← Back to Channels</a>
    </div>

    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <div class="card">
      <form method="POST" action="<%= channel && channel._id ? '/admin/channels/' + channel._id : '/admin/channels' %>">
        <div class="form-grid">
          <div class="form-group">
            <label>Channel Name</label>
            <input type="text" name="name" value="<%= channel ? channel.name || '' : '' %>" required placeholder="e.g. ESPN HD">
          </div>

          <div class="form-group">
            <label>Stream ID</label>
            <input type="number" name="stream_id" value="<%= channel ? channel.stream_id || '' : '' %>" required>
            <div class="form-hint">Unique numeric ID for this stream</div>
          </div>

          <div class="form-group full-width">
            <label>Stream URL (HLS)</label>
            <input type="url" name="stream_url" value="<%= channel ? channel.stream_url || '' : '' %>" required placeholder="https://example.com/live/stream.m3u8">
            <div class="form-hint">Real HLS .m3u8 stream URL (hidden from clients)</div>
          </div>

          <div class="form-group">
            <label>Category</label>
            <select name="category_id" required>
              <option value="">Select category...</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.category_id %>" <%= channel && channel.category_id === cat.category_id ? 'selected' : '' %>><%= cat.category_name %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label>Display Order</label>
            <input type="number" name="num" value="<%= channel ? channel.num || channel.stream_id || 1 : 1 %>" min="1">
          </div>

          <div class="form-group full-width">
            <label>Channel Icon URL</label>
            <input type="url" name="stream_icon" value="<%= channel ? channel.stream_icon || '' : '' %>" placeholder="https://example.com/logo.png">
            <div class="form-hint">URL to channel logo image (optional)</div>
          </div>

          <div class="form-group">
            <label>EPG Channel ID</label>
            <input type="text" name="epg_channel_id" value="<%= channel ? channel.epg_channel_id || '' : '' %>" placeholder="Optional">
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= channel && channel._id ? 'Update Channel' : 'Create Channel' %></button>
          <a href="/admin/channels" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </main>

  <script>document.getElementById('nav-channels').classList.add('active');</script>
</body>
</html>
