<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NovaStream Admin - <%= category && category._id ? 'Edit' : 'New' %> Category</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <%- include('../partials/sidebar') %>

  <main class="main">
    <div class="page-header">
      <div>
        <h2><%= category && category._id ? 'Edit' : 'New' %> Category</h2>
        <p><%= category && category._id ? 'Update category details' : 'Create a new channel category' %></p>
      </div>
      <a href="/admin/categories" class="btn btn-secondary">← Back to Categories</a>
    </div>

    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <div class="card">
      <form method="POST" action="<%= category && category._id ? '/admin/categories/' + category._id : '/admin/categories' %>">
        <div class="form-grid">
          <div class="form-group">
            <label>Category ID</label>
            <input type="text" name="category_id" value="<%= category ? category.category_id || '' : '' %>" required placeholder="e.g. 1">
            <div class="form-hint">Unique string identifier (e.g. 1, 2, 3)</div>
          </div>

          <div class="form-group">
            <label>Category Name</label>
            <input type="text" name="category_name" value="<%= category ? category.category_name || '' : '' %>" required placeholder="e.g. Sports">
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary"><%= category && category._id ? 'Update Category' : 'Create Category' %></button>
          <a href="/admin/categories" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </main>

  <script>document.getElementById('nav-categories').classList.add('active');</script>
</body>
</html>
